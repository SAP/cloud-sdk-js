{
  "name": "changesets-fixed-version-bump",
  "version": "1.0.0",
  "description": "Bumps the version of the root package.json and packages according to changesets.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "postcompile": "rolldown -c rolldown.config.ts",
    "lint": "eslint --ignore-pattern '!index.ts' && prettier --check **/*.ts",
    "lint:fix": "eslint --ignore-pattern '!index.ts' --fix --quiet && prettier --write **/*.ts",
    "check:dependencies": "depcheck --skip-missing=true .",
    "all": "pnpm install && pnpm run lint && pnpm run compile"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@changesets/get-release-plan": "^4.0.11",
    "execa": "^5.0.0",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@typescript/native": "npm:typescript@^7.0.2",
    "@sap-cloud-sdk/test-util-build-internal": "workspace:^",
    "depcheck": "^1.4.7",
    "eslint": "^10.2.1",
    "memfs": "^4.57.2",
    "rolldown": "1.1.5",
    "prettier": "^3.8.1"
  }
}
