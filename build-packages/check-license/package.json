{
  "name": "check-license",
  "version": "1.0.0",
  "description": "Checks if the licenses of the dependencies are allowed.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "postcompile": "ncc build lib/build-packages/check-license/index.js --out ../../.github/actions/check-license/",
    "lint": "eslint && prettier --check **/*.ts",
    "lint:fix": "eslint --fix --quiet && prettier --write **/*.ts",
    "all": "pnpm install && pnpm run lint && pnpm run compile"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@blueoak/list": "^15.0.0"
  },
  "devDependencies": {
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vercel/ncc": "^0.44.1",
    "eslint": "^10.2.1",
    "prettier": "^3.8.1"
  }
}
