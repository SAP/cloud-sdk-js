{
  "name": "merge-and-write-changelogs",
  "version": "1.0.0",
  "description": "Merges all changelogs produced by changesets into one changelog and writes it to a merged CHANGELOG file",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "postcompile": "rolldown -c rolldown.config.ts",
    "lint": "eslint --ignore-pattern '!index.ts' && prettier --check **/*.ts",
    "lint:fix": "eslint --ignore-pattern '!index.ts' --fix --quiet && prettier --write **/*.ts",
    "check:dependencies": "depcheck --skip-missing=true .",
    "all": "pnpm install && pnpm run lint && pnpm run compile"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@manypkg/get-packages": "^2.2.2"
  },
  "devDependencies": {
    "@sap-cloud-sdk/test-util-build-internal": "workspace:^",
    "depcheck": "^1.4.7",
    "eslint": "^10.2.1",
    "prettier": "^3.8.1",
    "rolldown": "1.1.0",
    "typescript": "~5.9.3"
  }
}
