{
  "name": "sap-cloud-sdk",
  "version": "4.5.1",
  "private": true,
  "sideEffects": false,
  "description": "SAP Cloud SDK for JavaScript",
  "homepage": "https://sap.github.io/cloud-sdk/docs/js/getting-started",
  "license": "Apache-2.0",
  "keywords": [
    "sap-cloud-sdk",
    "cloud-sdk",
    "sap-cloud-platform"
  ],
  "repository": "github:SAP/cloud-sdk-js",
  "tsd": {
    "directory": "test-packages/type-tests/test-new"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^10.33.0"
    }
  },
  "scripts": {
    "postinstall": "pnpm run compile",
    "compile": "turbo run compile",
    "test": "turbo run test",
    "test:unit": "turbo run test --filter=./packages/*",
    "test:build-packages": "turbo run test --filter=./build-packages/*",
    "test:integration": "turbo run test --filter=@sap-cloud-sdk/integration-tests",
    "test:type": "turbo run test --filter=@sap-cloud-sdk/type-tests",
    "test:e2e": "turbo run test --filter=@sap-cloud-sdk/e2e-tests",
    "test:self": "turbo run test --filter=@sap-cloud-sdk/self-tests",
    "generate": "turbo run generate --force",
    "readme": "turbo run readme",
    "doc": "pnpm exec ts-node scripts/generate-docs.ts",
    "version": "changeset version",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix --force",
    "checks": "turbo run check && pnpm run check:circular && pnpm run check:license && pnpm run check:test-service",
    "check:circular": "madge --extensions ts --ts-config=./tsconfig.json --circular --exclude 'dist|test-packages|connectivity/src/scp-cf/environment-accessor.ts|http-client/src/csrf-token-header.ts' ./packages",
    "check:dependencies": "turbo run check:dependencies",
    "check:license": "node ./.github/actions/check-license/index.js",
    "check:test-service": "pnpm run generate && pnpm exec ts-node scripts/check-test-service-for-changes.ts",
    "check:public-api": "cross-env INPUT_FORCE_INTERNAL_EXPORTS=true INPUT_EXCLUDED_PACKAGES=eslint-config,util,test-util node ./.github/actions/check-public-api/index.js",
    "connectivity": "pnpm --filter @sap-cloud-sdk/connectivity",
    "eslint-config": "pnpm --filter @sap-cloud-sdk/eslint-config",
    "generator": "pnpm --filter @sap-cloud-sdk/generator",
    "generator-common": "pnpm --filter @sap-cloud-sdk/generator-common",
    "http-client": "pnpm --filter @sap-cloud-sdk/http-client",
    "openapi": "pnpm --filter @sap-cloud-sdk/openapi",
    "resilience": "pnpm --filter @sap-cloud-sdk/resilience",
    "openapi-generator": "pnpm --filter @sap-cloud-sdk/openapi-generator",
    "odata-common": "pnpm --filter @sap-cloud-sdk/odata-common",
    "odata-v2": "pnpm --filter @sap-cloud-sdk/odata-v2",
    "odata-v4": "pnpm --filter @sap-cloud-sdk/odata-v4",
    "test-util": "pnpm --filter @sap-cloud-sdk/test-util",
    "util": "pnpm --filter @sap-cloud-sdk/util",
    "temporal-de-serializers": "pnpm --filter @sap-cloud-sdk/temporal-de-serializers",
    "e2e-tests": "pnpm --filter @sap-cloud-sdk/e2e-tests",
    "integration-tests": "pnpm --filter @sap-cloud-sdk/integration-tests",
    "type-tests": "pnpm --filter @sap-cloud-sdk/type-tests"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "@sap-cloud-sdk/connectivity": "workspace:^",
    "@sap-cloud-sdk/util": "workspace:^",
    "@sap-cloud-sdk/odata-common": "workspace:^",
    "@sap-cloud-sdk/odata-v2": "workspace:^",
    "@sap-cloud-sdk/odata-v4": "workspace:^",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.15",
    "@types/voca": "^1.4.6",
    "axios": "^1.13.6",
    "cross-env": "10.1.0",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.2",
    "execa": "^5.0.0",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-junit": "^16.0.0",
    "madge": "^8.0.0",
    "memfs": "^4.57.1",
    "prettier": "^3.8.1",
    "puppeteer": "^24.40.0",
    "semver": "^7.7.4",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "turbo": "^2.9.3",
    "typedoc": "^0.28.18",
    "typescript": "~5.9.3",
    "unionfs": "^4.6.0"
  }
}
