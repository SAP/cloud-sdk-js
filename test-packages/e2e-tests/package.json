{
  "name": "@sap-cloud-sdk/e2e-tests",
  "version": "4.6.0",
  "description": "End to end tests of the SAP Cloud SDK for JavaScript",
  "homepage": "https://sap.github.io/cloud-sdk/docs/js/overview",
  "license": "Apache-2.0",
  "private": true,
  "repository": "github:SAP/cloud-sdk-js",
  "scripts": {
    "pretest:e2e": "pnpm run start:service-server && pnpm run start:proxy-server",
    "posttest:e2e": "pnpm run stop:service-server && pnpm run stop:proxy-server",
    "start:service-server": "pm2 start server.js || pm2 restart server.js",
    "stop:service-server": "pm2 stop server.js",
    "start:proxy-server": "pm2 start test/proxy/proxy-server.js || pm2 restart test/proxy/proxy-server.js",
    "stop:proxy-server": "pm2 stop test/proxy/proxy-server.js",
    "test": "pnpm run test:e2e",
    "test:e2e": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js",
    "lint": "eslint --ext .ts . && prettier . --config ../../.prettierrc --ignore-path ../../.prettierignore -c",
    "lint:fix": "set TIMING=1 && eslint --ext .ts . --fix --quiet && prettier . --config ../../.prettierrc --ignore-path ../../.prettierignore -w --log-level error",
    "check:dependencies": "depcheck . --ignores='express,@sap/cds,@cap-js/sqlite,memfs,@sap-cloud-sdk/odata-v2,bignumber.js'",
    "generate-edmx": "cds compile srv -s TestService -2 edmx > TestService.edmx"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@cap-js/sqlite": "^2.2.0",
    "@jest/globals": "^30.3.0",
    "@sap-cloud-sdk/connectivity": "workspace:^",
    "@sap-cloud-sdk/generator": "workspace:^",
    "@sap-cloud-sdk/http-client": "workspace:^",
    "@sap-cloud-sdk/odata-common": "workspace:^",
    "@sap-cloud-sdk/odata-v2": "workspace:^",
    "@sap-cloud-sdk/odata-v4": "workspace:^",
    "@sap-cloud-sdk/test-services-e2e": "workspace:^",
    "@sap-cloud-sdk/test-services-openapi": "workspace:^",
    "@sap-cloud-sdk/util": "workspace:^",
    "@sap/cds": "^9.8.4",
    "@sap/cds-dk": "9.8.4",
    "axios": "^1.15.0",
    "bignumber.js": "^11.0.0",
    "depcheck": "^1.4.7",
    "execa": "^5.0.0",
    "express": "^4.22.1",
    "fs-extra": "^11.3.4",
    "http-proxy-middleware": "^3.0.5",
    "json-schema-faker": "^0.6.0",
    "memfs": "^4.57.2",
    "moment": "^2.30.1",
    "multer": "^2.1.1",
    "openapi-backend": "^5.16.1",
    "pm2": "^6.0.14",
    "prettier": "^3.8.1"
  },
  "cds": {
    "cdsc": {
      "odataFormat": "structured"
    },
    "requires": {
      "db": {
        "kind": "sqlite",
        "driver": "node",
        "credentials": {
          "database": ":memory:",
          "url": ":memory:"
        }
      }
    }
  }
}
