{
  "name": "@sap-cloud-sdk/type-tests",
  "version": "4.5.1",
  "description": "Tests to ensure correct types in the SAP Cloud SDK for JavaScript.",
  "homepage": "https://sap.github.io/cloud-sdk/docs/js/overview",
  "license": "Apache-2.0",
  "private": true,
  "types": "test",
  "repository": "github:SAP/cloud-sdk-js",
  "scripts": {
    "test": "pnpm exec tsd",
    "lint:fix": "set TIMING=1 && eslint --ext .ts . --fix --quiet && prettier . --config ../../.prettierrc --ignore-path ../../.prettierignore -w --log-level error"
  },
  "tsd": {
    "directory": "test"
  },
  "devDependencies": {
    "@sap-cloud-sdk/connectivity": "workspace:^",
    "@sap-cloud-sdk/generator": "workspace:^",
    "@sap-cloud-sdk/generator-common": "workspace:^",
    "@sap-cloud-sdk/http-client": "workspace:^",
    "@sap-cloud-sdk/odata-common": "workspace:^",
    "@sap-cloud-sdk/odata-v2": "workspace:^",
    "@sap-cloud-sdk/odata-v4": "workspace:^",
    "@sap-cloud-sdk/temporal-de-serializers": "workspace:^",
    "@sap-cloud-sdk/openapi": "workspace:^",
    "@sap-cloud-sdk/test-services-openapi": "workspace:^",
    "@sap-cloud-sdk/test-services-odata-v2": "workspace:^",
    "@sap-cloud-sdk/test-services-odata-v4": "workspace:^",
    "@types/jsonwebtoken": "^9.0.10",
    "bignumber.js": "^10.0.2",
    "moment": "^2.30.1",
    "tsd": "^0.33.0"
  }
}
